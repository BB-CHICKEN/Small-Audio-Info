{
  "manifest_version": 3,
  "name": "MoeKoe Music 累计听歌时长插件",
  "plugin_id":"Total-Play-time",
  "version": "2.1.0",
  "moekoe ": "true",
  "description": "MoeKoe Music 累计听歌时长插件",
  "author": {
    "name": "BB-Ji",
    "url": "https://github.com/BB-CHICKEN"
  },
  "permissions": ["storage"], 
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "累计听歌时长插件"
  },
  "icons": {
    "256": "icons.jpg"
  }
}